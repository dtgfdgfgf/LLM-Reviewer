# Copy this file to `.env` next to Reviewer.exe or the repo root.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=Reviewer
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Copilot CLI ─────────────────────────────────────────────────────────────
# Leave empty to use the default CLI resolution from PATH / SDK defaults.
COPILOT_CLI_PATH=

# ── Authentication ──────────────────────────────────────────────────────────
USE_LOGGED_IN_USER=true
GITHUB_TOKEN=

# ── BYOK ────────────────────────────────────────────────────────────────────
# Supported provider types: openai, anthropic, azure
BYOK_PROVIDER_TYPE=
BYOK_API_KEY=
BYOK_BASE_URL=

# ── Optional default models ────────────────────────────────────────────────
DEFAULT_ORCHESTRATOR_MODEL=claude-sonnet-4.6
DEFAULT_SECURITY_MODEL=claude-opus-4.6
DEFAULT_PERFORMANCE_MODEL=claude-sonnet-4.6
DEFAULT_READABILITY_MODEL=claude-haiku-4.5
DEFAULT_SYNTHESIZER_MODEL=claude-sonnet-4.6
